OPENAI_API_KEY=sk-your-key-here
# Linear personal API key — https://linear.app/settings/api
LINEAR_API_KEY=
# Notion integration token — optional, for setup_tracking.py
NOTION_TOKEN=
# Parent Notion page ID to create spec page
NOTION_PARENT_PAGE_ID=
# Existing Notion spec page ID to append sync updates
NOTION_PAGE_ID=
# Primary model for moment analysis
OPENAI_MODEL=gpt-5.5
# Second-pass verification model (optional; defaults to OPENAI_MODEL)
OPENAI_VERIFY_MODEL=
# Reasoning effort for GPT-5.x models: none, low, medium, high, xhigh
OPENAI_REASONING_EFFORT=medium
# Max output tokens (includes reasoning tokens on GPT-5.x — use a high value)
OPENAI_MAX_COMPLETION_TOKENS=16384
# Max moments to extract per category
MAX_MOMENTS_PER_GROUP=3
